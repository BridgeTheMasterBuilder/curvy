P = @(t) [0.5+0.3*t+3.9*t^2-4.7*t^3, 1.5+0.3*t+0.9*t^2-2.7*t^3];

s = 0.5

C = @(s) s^(1/3);

progress_curve(P, s, C)

C = @(s) s^2;

progress_curve(P, 0.5, C)

C = @(s) sin(s*pi/2);

progress_curve(P, 0.5, C)

C = @(s) 1/2+(1/2)*sin(2*s-1)*pi/2;

progress_curve(P, 0.5, C)

C = @(s) s;

progress_curve(P, 0.5, C)